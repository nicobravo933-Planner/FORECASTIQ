# ─── Backend API ───────────────────────────────────────────────
# URL del backend FastAPI (Railway en prod, localhost en dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Tier del servidor — chip del header + modelos disponibles.
# Fallback si /api/capabilities no responde (ej. backend no deployado todavía).
#   local  → PC del dev (LightGBM, Optuna, Nixtla habilitados)
#   ec2    → AWS EC2 producción
#   cloud  → Vercel / Netlify / sin backend ML
NEXT_PUBLIC_SERVER_TIER=local

# ─── Supabase (cliente público) ────────────────────────────────
# Solo anon key — nunca exponer service key en el frontend
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Better Auth ───────────────────────────────────────────────
# Generá con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=your-random-32-byte-hex-secret
BETTER_AUTH_URL=http://localhost:3000   # en prod: https://tudominio.com

# ─── Google OAuth ──────────────────────────────────────────────
# Crear en: console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# ─── GitHub OAuth ──────────────────────────────────────────────
# Crear en: github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxx
