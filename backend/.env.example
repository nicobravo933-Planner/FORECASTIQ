# ─── App ───────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ─── Logging ───────────────────────────────────────────────────
# LOG_FORMAT=pretty  <- dev (colores en terminal)
# LOG_FORMAT=json    <- prod (Railway/Loki lo parsea campo a campo)
LOG_LEVEL=INFO
LOG_FORMAT=pretty

# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Upstash Redis ─────────────────────────────────────────────
UPSTASH_REDIS_URL=rediss://default:...@...upstash.io:6379
UPSTASH_REDIS_TOKEN=...

# ─── Celery ────────────────────────────────────────────────────
# Dev:  CELERY_TASK_ALWAYS_EAGER=True  -> sin worker separado (sincrono)
# Prod: CELERY_TASK_ALWAYS_EAGER=False -> levantar worker con:
#       celery -A app.services.celery_app worker --loglevel=info
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── LLM ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=deepseek/deepseek-r1-0528:free
LLM_PROVIDER=openrouter

# Opcional: claves directas de proveedores
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ─── OpenTelemetry → Grafana Cloud ───────────────────────────────
# OTEL_ENABLED=false en dev (no envía nada), true en prod (Railway)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=forecastiq
OTEL_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_OTLP_HEADERS=Authorization=Basic <tu-token-base64>

# URL interna de Alloy en Railway (red privada)
# Dev: dejar vacío | Prod: http://alloy.railway.internal:3100/loki/api/v1/push
ALLOY_LOKI_URL=

# ─── Auth ──────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256

# URL del frontend Next.js (para validar tokens Better Auth)
# Dev: http://localhost:3000 | Prod: https://tudominio.vercel.app
BETTER_AUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
