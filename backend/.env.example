# ─── App ───────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
# Tier del servidor — controla el chip del header y los modelos disponibles:
#   "local" → PC del dev: todas las features (LightGBM, Optuna, Nixtla) habilitadas
#   "ec2"   → AWS EC2 prod: chip "AWS EC2", features según paquetes instalados
#   "cloud" → Vercel / serverless: solo modelos estadísticos básicos
SERVER_TIER=local   # en EC2 setear ec2, en Vercel setear cloud

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=pretty   # pretty (dev) | json (prod)

# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Upstash Redis (free tier permanente) ──────────────────────
# Dev local: dejar vacío y usar el Redis de docker-compose
# Prod EC2:  completar con las credenciales de Upstash
UPSTASH_REDIS_URL=rediss://default:...@...upstash.io:6379
UPSTASH_REDIS_TOKEN=...

# ─── Celery ────────────────────────────────────────────────────
# Dev:  CELERY_TASK_ALWAYS_EAGER=True  -> corre sincrono, sin worker separado
# Prod: CELERY_TASK_ALWAYS_EAGER=False -> worker levantado en docker-compose
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Concurrencia del worker: 1 en EC2 t3.micro (1 vCPU/1GB RAM), 2-4 en local
CELERYD_CONCURRENCY=1

# ─── Storage ────────────────────────────────────────────────────────────────
# supabase: uploads van a Supabase Storage (cloud/ec2) — TTL 24h automático
# local:    uploads van a disco local, los datos nunca salen de tu máquina
STORAGE_BACKEND=supabase
LOCAL_STORAGE_PATH=./data/user_uploads   # solo si STORAGE_BACKEND=local
DATASET_TTL_HOURS=24                     # 0 = nunca borrar
MAX_FILE_SIZE_MB=5                       # EC2: 5 MB | local: hasta 50 MB

# ─── MLflow (Dagshub) ──────────────────────────────────────────
# Dev local:   MLFLOW_TRACKING_URI=./mlruns  (filesystem, sin servidor)
# Prod EC2:    MLFLOW_TRACKING_URI=https://dagshub.com/<user>/forecastiq.mlflow
# Dagshub:     https://dagshub.com — free tier permanente, crear cuenta y repo
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_TRACKING_USERNAME=          # solo prod (Dagshub username)
MLFLOW_TRACKING_PASSWORD=          # solo prod (Dagshub token → Settings → Tokens)

# ─── LLM ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=deepseek/deepseek-r1-0528:free
LLM_PROVIDER=openrouter

GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ─── OpenTelemetry → Grafana Cloud ─────────────────────────────
# OTEL_ENABLED=false en dev (no envía nada)
# OTEL_ENABLED=true  en prod (EC2 → Grafana Cloud)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=forecastiq
OTEL_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_OTLP_HEADERS=Authorization=Basic <tu-token-base64>

# ─── Auth ──────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256

# URL del frontend (para validar tokens Better Auth)
# Dev: http://localhost:3000 | Prod: https://forecastiq.vercel.app
BETTER_AUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── MLflow / Dagshub (Fase 8) ───────────────────────────────
# Dev local:
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=
MLFLOW_EXPERIMENT_NAME=forecastiq
# Prod (EC2) — descomenta y completa con tu usuario Dagshub:
# MLFLOW_TRACKING_URI=https://dagshub.com/<tu-usuario>/forecastiq.mlflow
# MLFLOW_TRACKING_USERNAME=<tu-usuario-dagshub>
# MLFLOW_TRACKING_PASSWORD=<tu-token-dagshub>
